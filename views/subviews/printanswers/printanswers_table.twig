{#
    Corps du récapitulatif : titre du questionnaire + sections (groupes) →
    questions. Sobre : pas d'identifiant de groupe ni de sondage affiché.
    Chaque question est rendue par son template de type (question_types/).
#}

{% if (aSurveyInfo.printPdf != 1) %}
    <h1 class="fr-h4 printanswers-title">{{ aSurveyInfo.surveyls_title }}</h1>
{% endif %}

{% for groupid, group in aSurveyInfo.groupArray %}
    {% if (aSurveyInfo.printPdf == 1) and (not loop.first) %}
        <br pagebreak="true" />
    {% endif %}
    <section class="printanswers-section">
        {% if group.group_name %}
            <h2 class="fr-h6 printanswers-section__title">{{ group.group_name }}</h2>
        {% endif %}
        <div class="printanswers-section__body">
            {% for questionId, question in group.answerArray %}
                {% set questionTemplate = './subviews/printanswers/question_types/template_' ~ question.questionclass ~ '.twig' %}
                {{ include(questionTemplate) }}
            {% endfor %}
        </div>
    </section>
{% endfor %}
