{#
/**
 * Array Flexible (no dropdown) - DSFR Theme
 * Flexible array with radio buttons in cells
 */
#}

<!-- DSFR Array Flexible Table -->
<div class="ls-table-wrapper fr-table--responsive" role="group" aria-labelledby="ls-question-text-{{ basename }}">
    <table class="{{ coreClass }} fr-table fr-table--bordered" aria-labelledby="ls-question-text-{{ basename }}">
        <colgroup class="col-responses">
            <col class="col-answers" style='width: {{ answerwidth }}%;' />
            {{ sColumns }}
        </colgroup>

        <thead>
            <tr class="ls-heading">
                {{ sHeaders }}
            </tr>
        </thead>

        <tbody>
            {% for aRow in aRows %}
                {% if aRow.template is defined %}
                    {{ doRender('/survey/questions/answer/arrays/array/no_dropdown/rows/answer_row', aRow.content, true) }}
                {% else %}
                    {{ aRow }}
                {% endif %}
            {% endfor %}
        </tbody>
    </table>
</div>
