{#
    En-tête du récapitulatif des réponses.

    - En PDF (printPdf == 1) : injecte la feuille de style d'impression sobre.
    - En HTML : propose les deux exports PDF (PDF standard + queXML) sous forme
      d'un groupe de boutons DSFR aligné à droite, au-dessus du récapitulatif.

    Ouvre le conteneur `.fr-container` refermé par printanswers_foot.twig.
#}
{% if (aSurveyInfo.printPdf == 1) %}
    {{ include('./subviews/printanswers/printanswers_style.twig') }}
{% endif %}

<div class="fr-container fr-py-4w">
    {% if (aSurveyInfo.printPdf != 1) %}
        <div class="printanswers__actions fr-mb-4w">
            <ul class="fr-btns-group fr-btns-group--inline-md fr-btns-group--right fr-btns-group--icon-left">
                {# Bouton « Exporter en PDF » (mPDF) : affichable/masquable via l'option
                   de thème `show_pdf_export` (défaut : affiché). Le bouton queXML reste
                   toujours disponible. #}
                {% if aSurveyInfo.options.show_pdf_export|default('on') != 'off' %}
                <li>
                    {{ C.Html.form(aSurveyInfo.printAnswersHeadFormUrl, 'post') }}
                        <button class="fr-btn fr-btn--secondary fr-icon-download-line" type="submit">
                            {{ gT("PDF export") }}
                        </button>
                    {{ C.Html.endForm }}
                </li>
                {% endif %}
                <li>
                    {{ C.Html.form(aSurveyInfo.printAnswersHeadFormQueXMLUrl, 'post') }}
                        <button class="fr-btn fr-btn--tertiary fr-icon-download-line" type="submit">
                            {{ gT("queXML PDF export") }}
                        </button>
                    {{ C.Html.endForm }}
                </li>
            </ul>
        </div>
    {% endif %}
