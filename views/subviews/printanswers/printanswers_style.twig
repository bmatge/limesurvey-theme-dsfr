<style>
/*!
 * Récapitulatif des réponses — habillage de l'export PDF (mPDF).
 *
 * Ce bloc n'est inclus QUE pour le PDF (printPdf == 1) : les règles sont donc
 * volontairement HORS @media print. Le moteur PDF de LimeSurvey n'applique pas
 * de façon fiable les blocs @media print ; en restant en CSS « normal », on
 * garantit l'application.
 *
 * Contraintes mPDF : pas de flexbox/grid → mise en page EMPILÉE (libellé puis
 * réponse), pas de var() → couleurs littérales. Les tailles de police sont
 * FORCÉES (!important, y compris sur les enfants) pour neutraliser d'éventuels
 * styles inline (font-size) présents dans le HTML des questions/réponses.
 * Palette DSFR : blue-france #000091, titres #161616, texte #3a3a3a.
 */
body {
    font-family: "Marianne", Arial, sans-serif;
    font-size: 11pt;
    line-height: 1.4;
    color: #161616;
    background: #fff;
}

/* Masquages */
.printanswers__actions, button, input[type="submit"], input[type="button"],
form, .fr-header, .fr-footer, .fr-skiplinks, nav { display: none !important; }

/* Titre du questionnaire + sections (groupes) */
.printanswers-title {
    font-size: 15pt !important;
    font-weight: 700 !important;
    color: #000091;
    margin: 0 0 1rem;
}
.printanswers-section { margin: 0 0 1rem; }
.printanswers-section__title {
    font-size: 12pt !important;
    font-weight: 700 !important;
    color: #000091;
    border-bottom: 2px solid #000091;
    padding-bottom: 0.2rem;
    margin: 0 0 0.5rem;
    page-break-after: avoid;
}

/* Une question : libellé puis réponse, EMPILÉS. Tailles forcées pour
   neutraliser les styles inline éventuels du contenu. */
.question-container-printanswers {
    display: block;
    padding: 0.35rem 0;
    border-bottom: 1px solid #dddddd;
    page-break-inside: avoid;
}
.printanswers-q__label,
.printanswers-q__answer {
    display: block;
    width: 100% !important;
    float: none !important;
}
.printanswers-q__label,
.printanswers-q__label * {
    font-size: 11pt !important;
    font-weight: 700 !important;
    color: #161616;
    line-height: 1.35;
}
.printanswers-q__answer {
    color: #3a3a3a;
    padding-left: 1rem;
    margin-top: 0.15rem;
}
.printanswers-q__answer,
.printanswers-q__answer * {
    font-size: 11pt !important;
    line-height: 1.35;
}
.printanswers-q__answer strong,
.printanswers-q__answer b,
.printanswers-sub__value { font-weight: 700 !important; }
.printanswers-empty { color: #666666; font-style: italic; }

/* Réponses multiples / classement */
.printanswers-q__list, .printanswers-q__ranked { margin: 0; padding-left: 1.2rem; }
.printanswers-q__list { list-style: square; }
.printanswers-q__ranked { list-style: decimal; }
.printanswers-q__list li, .printanswers-q__ranked li { margin: 0 0 0.1rem; }

/* Sous-questions : « libellé : valeur » sur une ligne */
.printanswers-sub { padding: 0.1rem 0; }
.printanswers-sub__label { color: #666666; }
.printanswers-sub__label:after { content: " : "; }
.printanswers-sub__value { color: #161616; }

/* Question d'information (boilerplate) */
.printanswers-boilerplate, .printanswers-boilerplate * { font-size: 11pt !important; color: #3a3a3a; }

/* Tableaux (échelles doubles, multi-flexi) */
.printanswers-q__answer table { border-collapse: collapse; width: 100%; page-break-inside: avoid; }
.printanswers-q__answer th, .printanswers-q__answer td {
    border: 1px solid #cccccc;
    padding: 0.2rem 0.35rem;
    text-align: left;
    font-size: 9.5pt !important;
    vertical-align: top;
}
.printanswers-q__answer th { background: #f6f6f6; font-weight: 700 !important; }

/* Liens : pas d'URL affichée en PDF */
a[href]:after { content: none !important; }
a { color: #000091; text-decoration: none; }
</style>
<style>@page { margin: 1.5cm; }</style>
